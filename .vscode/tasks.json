{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CitoNauta: configurar agente",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\setup_agent.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "CitoNauta: preflight",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["scripts/run_citonauta_agent.py", "preflight"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "CitoNauta: vista previa de Bioestadística",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts/run_citonauta_agent.py",
        "run",
        "--subject",
        "bioestadistica",
        "--dry-run"
      ],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "CitoNauta: terminar siguiente asignatura",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["scripts/run_citonauta_agent.py", "run", "--limit", "1"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "CitoNauta: terminar todas las asignaturas",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["scripts/run_citonauta_agent.py", "run"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "CitoNauta: reintentar fallidas",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["scripts/run_citonauta_agent.py", "run", "--retry-failed"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    },
    {
      "label": "CitoNauta: estado del agente",
      "type": "process",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["scripts/run_citonauta_agent.py", "status"],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": []
    }
  ]
}
