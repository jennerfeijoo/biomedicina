  "shared_unit_contract": {
    "target_words": "1000-1600 palabras sustantivas por unidad",
    "required_sections": [
      "objetivos de aprendizaje observables",
      "teoría desarrollada con intuición, formalización, supuestos y límites",
      "definiciones y glosario de 8-15 términos",
      "caso o ejemplo biomédico razonado paso a paso",
      "actividad guiada con solución o criterios de comprobación",
      "errores frecuentes y cómo corregirlos",
      "autoevaluación de 5-8 preguntas con respuestas justificadas",
      "3-6 fuentes académicas o institucionales trazables"
    ],
    "minimum_review_scores": {
      "clarity": 8,
      "scientific_rigor": 8,
      "pedagogy": 8,
      "completeness": 8
    },
    "forbidden": [
      "marcadores pendientes",
      "referencias inventadas",
      "texto genérico reutilizado entre unidades",
      "recomendaciones clínicas personales",
      "duplicación sustantiva de otra asignatura"
    ],
    "editorial_notice": "Material educativo generado y revisado automáticamente; requiere revisión docente experta. No equivale a acreditación universitaria ni a validación clínica."
  },
  "publication_policy": {
    "atomic_unit": "una unidad validada",
    "storage_pattern": "data/generated_units/{subject_id}/unit-{unit:02d}.json",
    "page_progress": "mostrar unidades disponibles, en revisión y pendientes",
    "git_policy": "un commit y un pull request por unidad durante la estabilización inicial",
    "final_course_gate": "al completar todas las unidades, auditar continuidad, progresión, duplicación, cobertura de resultados y referencias"
  },
  "unit_projection": {
